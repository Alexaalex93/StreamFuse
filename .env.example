# General
STREAMFUSE_ENV=development

# Backend
STREAMFUSE_DEBUG=true
STREAMFUSE_DATABASE_URL=sqlite:////data/streamfuse.db
STREAMFUSE_AUTO_SEED_MOCK=true
STREAMFUSE_UVICORN_WORKERS=2

STREAMFUSE_TAUTULLI_BASE_URL=http://localhost:8181
STREAMFUSE_TAUTULLI_API_KEY=changeme
STREAMFUSE_TAUTULLI_USE_MOCK=true
STREAMFUSE_TAUTULLI_HISTORY_LENGTH=100

STREAMFUSE_SFTPGO_BASE_URL=http://localhost:8080
STREAMFUSE_SFTPGO_API_KEY=changeme
STREAMFUSE_SFTPGO_USE_MOCK=true
STREAMFUSE_SFTPGO_TRANSFER_LOG_JSON_PATH=
STREAMFUSE_SFTPGO_STALE_SECONDS=180
STREAMFUSE_SFTPGO_LOG_LIMIT=200

STREAMFUSE_POSTER_PLACEHOLDER_PATH=app/poster_resolver/assets/placeholder.svg
STREAMFUSE_POSTER_ALLOWED_ROOTS=

# Frontend
VITE_API_BASE=http://localhost:8000/api/v1

# Optional PostgreSQL (for docker compose --profile postgres ...)
POSTGRES_DB=streamfuse
POSTGRES_USER=streamfuse
POSTGRES_PASSWORD=streamfuse
# STREAMFUSE_DATABASE_URL=postgresql+psycopg://streamfuse:streamfuse@db:5432/streamfuse
# Production overrides (docker-compose.prod.yml)
STREAMFUSE_DATABASE_URL_PROD=postgresql+psycopg://streamfuse:streamfuse@db:5432/streamfuse
STREAMFUSE_AUTO_SEED_MOCK_PROD=false
