<?xml version="1.0"?>
<PLUGIN
  name="streamfuse-widget"
  author="alexaalex93"
  version="0.1.0"
  pluginURL="https://raw.githubusercontent.com/Alexaalex93/StreamFuse/main/plugin-unraid/plg/streamfuse-widget.plg"
  icon="https://raw.githubusercontent.com/Alexaalex93/StreamFuse/main/plugin-unraid/assets/streamfuse-icon.png">

  <FILE
    Name="/boot/config/plugins/streamfuse-widget/unraid-widget.tar.gz"
    URL="https://raw.githubusercontent.com/Alexaalex93/StreamFuse/main/plugin-unraid/release/unraid-widget.tar.gz" />

  <FILE Run="/bin/bash">
    <INLINE>
mkdir -p /usr/local/emhttp/plugins/streamfuse-widget
tar -xzf /boot/config/plugins/streamfuse-widget/unraid-widget.tar.gz -C /usr/local/emhttp/plugins/streamfuse-widget
chmod -R 755 /usr/local/emhttp/plugins/streamfuse-widget
    </INLINE>
  </FILE>

  <FILE Run="/bin/bash" Method="remove">
    <INLINE>
rm -rf /usr/local/emhttp/plugins/streamfuse-widget
rm -rf /boot/config/plugins/streamfuse-widget
    </INLINE>
  </FILE>
</PLUGIN>
